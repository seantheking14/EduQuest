/* =========================================================
   Learning Modules – 2D Gamified Styles
   ========================================================= */

/* ── Hero / World Map Header ── */
.learning-hero {
    text-align: center;
    padding: 40px 20px 24px;
    position: relative;
    overflow: hidden;
}

.world-decoration {
    position: relative;
    height: 60px;
}

.cloud {
    position: absolute;
    font-size: 32px;
    opacity: 0.6;
    animation: float-cloud 8s ease-in-out infinite;
}
.cloud-1 { left: 10%; top: 0; animation-delay: 0s; }
.cloud-2 { right: 15%; top: 10px; animation-delay: 2s; font-size: 24px; }
.cloud-3 { left: 50%; top: 5px; animation-delay: 4s; }

@keyframes float-cloud {
    0%, 100% { transform: translateX(0) translateY(0); }
    50% { transform: translateX(20px) translateY(-8px); }
}

.page-title {
    font-size: 36px;
    font-weight: 800;
    color: #1f2937;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
}

.page-subtitle {
    font-size: 16px;
    color: #6b7280;
    margin-bottom: 24px;
}

.overall-progress {
    display: flex;
    justify-content: center;
}

.progress-stars {
    display: flex;
    align-items: center;
    gap: 8px;
}

.progress-stars .star {
    font-size: 28px;
    filter: grayscale(100%);
    transition: filter 0.4s, transform 0.3s;
}

.progress-stars .star.active {
    filter: grayscale(0%);
    animation: star-pulse 2s ease-in-out infinite;
}

.progress-stars .star.completed {
    filter: grayscale(0%) brightness(1.2);
    transform: scale(1.1);
}

.star-connector {
    width: 40px;
    height: 3px;
    background: #e5e7eb;
    border-radius: 2px;
    position: relative;
}

.star-connector.filled {
    background: linear-gradient(90deg, #fbbf24, #f59e0b);
}

@keyframes star-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
}

/* ── Loading ── */
.loading-state {
    text-align: center;
    padding: 60px 20px;
    color: #6b7280;
}

.loading-spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #e5e7eb;
    border-top-color: #8b5cf6;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ── Subject Cards (World Islands) ── */
.subjects-world {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-bottom: 40px;
}

.subject-island {
    position: relative;
    border-radius: 18px;
    padding: 32px;
    background: white;
    border: 2px solid #e5e7eb;
    border-bottom: 5px solid #e5e7eb;
    transition: all 0.12s;
    overflow: hidden;
}

.subject-island::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    border-radius: 24px 24px 0 0;
}

.subject-island.math::before { background: linear-gradient(90deg, #ef4444, #f97316); }
.subject-island.self_care::before { background: linear-gradient(90deg, #10b981, #34d399); }
.subject-island.english::before { background: linear-gradient(90deg, #3b82f6, #6366f1); }

.subject-island:hover:not(.locked) {
    transform: translateY(2px);
    border-bottom-width: 2px;
}

.subject-island.locked {
    opacity: 0.55;
    filter: grayscale(40%);
    cursor: not-allowed;
}

.subject-island.locked::after {
    content: '🔒';
    position: absolute;
    top: 16px;
    right: 20px;
    font-size: 28px;
}

/* Island Header */
.island-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
}

.island-icon {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    position: relative;
    flex-shrink: 0;
}

.island-icon .icon-bg {
    position: absolute;
    inset: 0;
    border-radius: 20px;
    opacity: 0.15;
}

.subject-island.math .island-icon .icon-bg { background: #ef4444; }
.subject-island.self_care .island-icon .icon-bg { background: #10b981; }
.subject-island.english .island-icon .icon-bg { background: #3b82f6; }

.island-icon .icon-emoji {
    position: relative;
    z-index: 1;
    font-size: 40px;
}

.island-info {
    flex: 1;
}

.island-title {
    font-size: 24px;
    font-weight: 800;
    color: #1f2937;
    margin-bottom: 4px;
}

.island-desc {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.5;
    margin-bottom: 8px;
}

.island-meta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
}

.meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: #f3f4f6;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
    color: #4b5563;
    border: 1px solid #e5e7eb;
}

/* Island Progress */
.island-progress {
    margin-bottom: 20px;
}

.progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.progress-label {
    font-size: 14px;
    font-weight: 600;
    color: #374151;
}

.progress-count {
    font-size: 14px;
    color: #6b7280;
}

.progress-bar-track {
    height: 12px;
    background: #f3f4f6;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
}

.progress-bar-fill {
    height: 100%;
    border-radius: 6px;
    transition: width 0.6s ease;
    position: relative;
}

.subject-island.math .progress-bar-fill { background: linear-gradient(90deg, #ef4444, #f97316); }
.subject-island.self_care .progress-bar-fill { background: linear-gradient(90deg, #10b981, #34d399); }
.subject-island.english .progress-bar-fill { background: linear-gradient(90deg, #3b82f6, #6366f1); }

.progress-bar-fill::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 20px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3));
    border-radius: 0 6px 6px 0;
}

/* Lesson Path (dotted trail) */
.lesson-path {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 16px 0;
}

.lesson-node {
    display: flex;
    align-items: center;
    gap: 8px;
}

.lesson-dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    border: 3px solid #e5e7eb;
    background: white;
    transition: all 0.3s;
    cursor: pointer;
    position: relative;
}

.lesson-dot.completed {
    border-color: #10b981;
    background: #10b981;
    color: white;
}

.lesson-dot.available, .lesson-dot.in_progress {
    border-color: #fbbf24;
    background: #fffbeb;
    color: #f59e0b;
    animation: node-glow 2s ease-in-out infinite;
}

.lesson-dot.in_progress {
    border-color: #8b5cf6;
    background: #f5f3ff;
    color: #8b5cf6;
}

.lesson-dot.locked {
    border-color: #d1d5db;
    background: #f9fafb;
    color: #d1d5db;
    cursor: not-allowed;
}

@keyframes node-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(251, 191, 36, 0.3); }
    50% { box-shadow: 0 0 0 6px rgba(251, 191, 36, 0); }
}

.lesson-connector {
    width: 20px;
    height: 2px;
    background: #e5e7eb;
}

.lesson-connector.filled {
    background: #10b981;
}

.lesson-dot-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: #1f2937;
    color: white;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
    z-index: 10;
    pointer-events: none;
}

.lesson-dot:hover .lesson-dot-tooltip {
    display: block;
}

/* Island Action */
.island-action {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
}

.btn-explore {
    padding: 12px 28px;
    border-radius: 12px;
    border: 2px solid rgba(0,0,0,0.15);
    border-bottom: 4px solid rgba(0,0,0,0.25);
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.subject-island.math .btn-explore { background: #ef4444; color: white; }
.subject-island.self_care .btn-explore { background: #10b981; color: white; }
.subject-island.english .btn-explore { background: #3b82f6; color: white; }

.btn-explore:hover { transform: translateY(2px); border-bottom-width: 2px; }

.btn-explore:disabled {
    background: #d1d5db !important;
    cursor: not-allowed;
    transform: none !important;
    box-shadow: none !important;
}

.xp-badge-island {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 14px;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    border-radius: 20px;
    border: 2px solid #f59e0b;
    border-bottom: 3px solid #d97706;
    font-size: 13px;
    font-weight: 800;
    color: #92400e;
}

/* Status badges */
.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 12px;
    border-radius: 16px;
    border: 2px solid transparent;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.status-badge.completed { border-color: #10b981; }
.status-badge.active { border-color: #3b82f6; }
.status-badge.locked { border-color: #d1d5db; }

.status-badge.completed {
    background: #d1fae5;
    color: #065f46;
}

.status-badge.active {
    background: #dbeafe;
    color: #1e40af;
}

.status-badge.locked {
    background: #f3f4f6;
    color: #9ca3af;
}

/* ── Empty state ── */
.empty-state {
    text-align: center;
    padding: 60px 20px;
    color: #6b7280;
}

.empty-state-icon {
    font-size: 64px;
    margin-bottom: 16px;
}

/* ── Course Modules Section ── */
.course-modules-section {
    margin-bottom: 40px;
}

.section-header-row {
    margin-bottom: 20px;
}

.section-title {
    font-size: 24px;
    font-weight: 800;
    color: #1f2937;
    margin-bottom: 4px;
}

.section-subtitle {
    font-size: 14px;
    color: #6b7280;
}

.course-modules-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.cm-course-card {
    background: white;
    border-radius: 16px;
    border: 2px solid #e5e7eb;
    overflow: hidden;
    transition: box-shadow 0.2s;
}

.cm-course-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.cm-course-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    background: #fafbfc;
    border-bottom: 1px solid #e5e7eb;
}

.cm-course-title {
    font-size: 18px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 4px;
}

.cm-course-meta {
    font-size: 13px;
    color: #6b7280;
}

.cm-course-stats {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
}

.cm-stat {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: #f3f4f6;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    color: #4b5563;
}

.cm-modules-list {
    padding: 16px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.cm-module {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
}

.cm-module-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: #f9fafb;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
}

.cm-module-header:hover {
    background: #f3f4f6;
}

.cm-arrow {
    font-size: 10px;
    color: #9ca3af;
    transition: transform 0.2s;
    display: inline-block;
}

.cm-arrow-open {
    transform: rotate(90deg);
}

.cm-module-title {
    font-size: 15px;
    font-weight: 600;
    color: #374151;
    flex: 1;
}

.cm-material-count {
    font-size: 12px;
    color: #9ca3af;
    font-weight: 500;
}

.cm-module-body {
    padding: 8px 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.cm-module-body.cm-collapsed {
    display: none;
}

.cm-material-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    transition: background 0.15s;
}

.cm-material-item:hover {
    background: #f9fafb;
}

.cm-mat-icon {
    font-size: 22px;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    border-radius: 8px;
}

.cm-mat-info {
    flex: 1;
    min-width: 0;
}

.cm-mat-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.cm-mat-detail {
    display: block;
    font-size: 12px;
    color: #9ca3af;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.cm-text-content {
    margin-top: 6px;
    font-size: 13px;
    color: #4b5563;
    line-height: 1.5;
    max-height: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
}

.cm-mat-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.cm-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
    border: 1px solid #e5e7eb;
    cursor: pointer;
}

.cm-btn-preview {
    background: #eff6ff;
    color: #2563eb;
    border-color: #bfdbfe;
}

.cm-btn-preview:hover {
    background: #dbeafe;
}

.cm-btn-download {
    background: #f0fdf4;
    color: #16a34a;
    border-color: #bbf7d0;
}

.cm-btn-download:hover {
    background: #dcfce7;
}

.cm-empty {
    text-align: center;
    padding: 16px;
    color: #9ca3af;
    font-size: 13px;
}

/* ── Assignment Submission UI ── */
.cm-assignment-item {
    flex-direction: column;
    align-items: flex-start;
}

.cm-assignment-item > .cm-mat-icon {
    align-self: flex-start;
    margin-top: 2px;
}

.cm-assignment-info {
    width: 100%;
}

.cm-submission-status {
    margin-top: 10px;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 13px;
}

.cm-status-submitted {
    background: #eff6ff;
    border-color: #bfdbfe;
}

.cm-status-graded {
    background: #f0fdf4;
    border-color: #bbf7d0;
}

.cm-status-returned {
    background: #fefce8;
    border-color: #fde68a;
}

.cm-sub-badge {
    font-weight: 700;
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(0,0,0,0.06);
}

.cm-sub-file {
    color: #6b7280;
}

.cm-sub-date {
    color: #9ca3af;
    font-size: 12px;
}

.cm-sub-grade {
    color: #059669;
    font-weight: 600;
}

.cm-sub-feedback {
    width: 100%;
    margin-top: 4px;
    padding: 8px 10px;
    background: rgba(0,0,0,0.03);
    border-radius: 8px;
    font-size: 13px;
    color: #374151;
    line-height: 1.5;
}

.cm-upload-prompt,
.cm-resubmit {
    margin-top: 10px;
}

.cm-btn-upload {
    background: #8b5cf6 !important;
    color: white !important;
    border-color: #7c3aed !important;
    padding: 8px 16px !important;
    font-size: 13px !important;
}

.cm-btn-upload:hover {
    background: #7c3aed !important;
}

.cm-btn-resubmit {
    background: #f3f4f6 !important;
    color: #4b5563 !important;
    border-color: #d1d5db !important;
}

.cm-submit-form {
    margin-top: 12px;
    padding: 16px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

.cm-upload-zone {
    position: relative;
    border: 2px dashed #d1d5db;
    border-radius: 10px;
    padding: 24px 16px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    margin-bottom: 10px;
}

.cm-upload-zone:hover {
    border-color: #8b5cf6;
    background: #faf5ff;
}

.cm-upload-zone.cm-dragover {
    border-color: #8b5cf6;
    background: #f5f3ff;
}

.cm-file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
}

.cm-upload-zone-inner {
    pointer-events: none;
}

.cm-upload-zone-inner span {
    font-size: 28px;
    display: block;
    margin-bottom: 6px;
}

.cm-upload-zone-inner p {
    font-size: 13px;
    color: #6b7280;
    margin: 2px 0;
}

.cm-upload-hint {
    font-size: 11px !important;
    color: #9ca3af !important;
}

.cm-selected-file {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 8px;
    margin-bottom: 10px;
    font-size: 13px;
    color: #1e40af;
    font-weight: 500;
}

.cm-btn-clear {
    background: none;
    border: none;
    cursor: pointer;
    color: #6b7280;
    font-size: 14px;
    padding: 2px 6px;
    border-radius: 4px;
}

.cm-btn-clear:hover {
    background: #fee2e2;
    color: #dc2626;
}

.cm-notes-input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 13px;
    font-family: inherit;
    resize: vertical;
    margin-bottom: 10px;
    box-sizing: border-box;
}

.cm-notes-input:focus {
    outline: none;
    border-color: #8b5cf6;
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
}

.cm-submit-actions {
    display: flex;
    gap: 8px;
}

.cm-btn-submit {
    background: #8b5cf6 !important;
    color: white !important;
    border-color: #7c3aed !important;
    padding: 8px 18px !important;
    font-weight: 700 !important;
}

.cm-btn-submit:hover {
    background: #7c3aed !important;
}

.cm-btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.cm-btn-cancel {
    background: #f3f4f6 !important;
    color: #4b5563 !important;
}

.cm-upload-progress {
    margin-top: 10px;
}

.cm-progress-bar {
    height: 8px;
    background: #e5e7eb;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 4px;
}

.cm-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #8b5cf6, #6366f1);
    border-radius: 4px;
    transition: width 0.2s;
    width: 0;
}

.cm-progress-text {
    font-size: 12px;
    color: #6b7280;
}

/* ── Responsive ── */
@media (max-width: 768px) {
    .page-title { font-size: 28px; }
    .island-header { flex-direction: column; text-align: center; }
    .island-icon { margin: 0 auto; }
    .island-meta { justify-content: center; }
    .island-action { flex-direction: column; gap: 12px; }
    .lesson-path { justify-content: center; }
    .subject-island { padding: 24px 20px; }
    .cm-course-header { flex-direction: column; align-items: flex-start; gap: 10px; }
    .cm-material-item { flex-wrap: wrap; }
    .cm-mat-actions { width: 100%; justify-content: flex-start; margin-top: 4px; }
}

@media (max-width: 480px) {
    .page-title { font-size: 24px; }
    .page-subtitle { font-size: 14px; }
    .subject-island { padding: 20px 16px; border-radius: 16px; }
    .island-title { font-size: 20px; }
    .island-icon { width: 64px; height: 64px; }
    .island-icon .icon-emoji { font-size: 32px; }
    .island-desc { font-size: 13px; }
    .meta-tag { font-size: 11px; padding: 3px 8px; }
    .btn-explore { padding: 10px 20px; font-size: 14px; }
    .lesson-dot { width: 28px; height: 28px; font-size: 13px; }
    .lesson-connector { width: 14px; }
    .progress-stars .star { font-size: 22px; }
    .star-connector { width: 28px; }
    .learning-hero { padding: 24px 16px 16px; }
    .subjects-world { gap: 20px; }
    .cloud { font-size: 20px; }
}
